
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'demo@learnstream.ai' || 
        request.auth.uid == 'dvoJg4wCr2e2DZABWjlXITbtVCE3' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isInstructor() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor';
    }

    function isPremium() {
      return isAdmin() || (isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isPremiumSubscriber == true);
    }

    function hasPurchased(collectionName, docId) {
      return isSignedIn() && (
        (collectionName == 'courses' && docId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('purchasedCourses', [])) ||
        (collectionName == 'modules' && docId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('purchasedModules', [])) ||
        (collectionName == 'lessons' && docId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('purchasedLessons', [])) ||
        (collectionName == 'podcasts' && docId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('purchasedPodcasts', [])) ||
        (collectionName == 'coding_challenges' && docId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('purchasedChallenges', []))
      );
    }

    // ⭐ CONFIGURACIÓN GLOBAL (Público Lectura)
    match /settings/branding {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ✅ ADMIN: acceso total a todo el sistema
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if true; 
      allow list: if true;
      allow create: if isOwner(userId) && (
        !request.resource.data.keys().hasAny(['premiumUpdatedAt', 'lastEpaycoRef']) &&
        (
          request.auth.token.email == 'demo@learnstream.ai' || 
          (!request.resource.data.keys().hasAny(['role']) || request.resource.data.role == 'student')
        ) &&
        (!request.resource.data.keys().hasAny(['isPremiumSubscriber']) || request.resource.data.isPremiumSubscriber == false)
      );
      allow update: if isAdmin() || (isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isPremiumSubscriber', 'premiumUpdatedAt', 'lastEpaycoRef'])));
      allow delete: if isAdmin();

      match /courseProgress/{courseId} {
        allow read: if isOwner(userId) || isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid); 
        allow write: if isOwner(userId) || isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);
      }
      
      match /challenge_submissions/{submissionId} {
        allow read: if true; 
        allow write: if isOwner(userId) || isAdmin();
      }

      match /achievements/{achievementId} {
        allow read: if true; 
        allow write: if isOwner(userId) || isAdmin();
      }

      match /settings/{settingId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }

      match /dailyMissions/{missionId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ⭐ Collection Group Rule for Ratings (RealTestimonials)
    match /{path=**}/ratings/{ratingId} {
      allow read: if true;
    }

    // ⭐ Collection Group Rule for courseProgress (GroupsManager queries real-time)
    match /{path=**}/courseProgress/{courseId} {
      allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);
    }

    match /instructor_applications/{appId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /promotions/{promoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coding_challenges/{challengeId} { 
      allow read: if true; 
      allow create: if (isAdmin() || isSignedIn()) && request.resource.data.instructorId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.instructorId == request.auth.uid && request.resource.data.instructorId == resource.data.instructorId);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.instructorId == request.auth.uid);

      match /premium/data {
        allow read: if isPremium() || 
                      hasPurchased('coding_challenges', challengeId) || 
                      get(/databases/$(database)/documents/coding_challenges/$(challengeId)).data.isFree == true;
      }
    }
    
    match /courses/{courseId} {
      allow read: if true;
      allow create: if (isAdmin() || isInstructor()) && request.resource.data.instructorId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.instructorId == request.auth.uid && request.resource.data.instructorId == resource.data.instructorId);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.instructorId == request.auth.uid);

      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);

            match /lessons/{lessonId} {
                allow read: if true;
                allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);

                match /premium/data {
                    allow read: if isPremium() || 
                                  hasPurchased('courses', courseId) || 
                                  hasPurchased('modules', moduleId) || 
                                  hasPurchased('lessons', lessonId) ||
                                  get(/databases/$(database)/documents/courses/$(courseId)).data.isFree == true;
                }

                match /resources/{resourceId} {
                    allow read: if true;
                    allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);
                }
            }
      }
      
      match /groups/{groupId} {
        allow read: if true;
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);
      }
      
      match /virtualClasses/{classId} {
        allow read: if true;
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);
      }
    }

    match /notifications/{notifId} {
      // ✅ 'list' no puede usar resource.data — se permite a cualquier user autenticado
      // La privacidad está garantizada por el filtro where() en el cliente
      allow list: if isSignedIn();

      // 'get' sí tiene resource.data disponible
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        request.auth.uid == 'dvoJg4wCr2e2DZABWjlXITbtVCE3' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );

      allow update: if isSignedIn() && 
        resource.data.userId == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        request.auth.uid == 'dvoJg4wCr2e2DZABWjlXITbtVCE3' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    match /transactions/{transId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.instructorId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    // ⭐ Reseñas: legibles por todos, escribibles solo por el propietario
    match /reviews/{courseId}/ratings/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    // CERTIFICATES (público lectura para validación vía QR)
    match /certificates/{certificateId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == request.resource.data.userId || isAdmin()); // Solo puede generarlo el estudiante completado o un admin
    }

    // ⭐ FORO DE DISCUSIÓN (Q&A por Lección)
    match /lesson_discussions/{discussionId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 🛰️ PODCASTS (Público lectura, Admin escritura)
    match /podcasts/{podcastId} {
      allow read: if true;
      allow write: if isAdmin();

      match /premium/data {
        allow read: if isPremium() || 
                      hasPurchased('podcasts', podcastId) ||
                      get(/databases/$(database)/documents/podcasts/$(podcastId)).data.isFree == true;
      }
    }

    // 🗺️ RUTAS DE APRENDIZAJE (Bootcamps)
    match /paths/{pathId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 📢 ANUNCIOS (Público lectura para popups)
    match /announcements/{annId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
