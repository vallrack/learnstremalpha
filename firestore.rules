
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Permitimos lectura pública para el Portfolio Profesional
      allow get: if true; 
      allow create: if isOwner(userId) && (!request.resource.data.keys().hasAny(['role', 'isPremiumSubscriber', 'premiumUpdatedAt', 'lastEpaycoRef']));
      allow list: if true;
      allow update: if isAdmin() || (isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isPremiumSubscriber', 'premiumUpdatedAt', 'lastEpaycoRef'])));
      allow delete: if isAdmin();

      match /courseProgress/{courseId} {
        allow read: if isOwner(userId) || isAdmin(); // Privado, no sale en portfolio público
        allow write: if isOwner(userId) || isAdmin();
      }
      
      match /challenge_submissions/{submissionId} {
        allow read: if true; // Público para el portfolio
        allow write: if isOwner(userId) || isAdmin();
      }

      match /achievements/{achievementId} {
        allow read: if true; // Público para el portfolio
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /instructor_applications/{appId} {
      allow create: if isSignedIn();
      allow read, write: if isAdmin();
    }

    match /promotions/{promoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coding_challenges/{challengeId} { 
      allow read: if true; 
      allow write: if isAdmin() || (isSignedIn() && request.resource.data.instructorId == request.auth.uid);
    }
    
    match /courses/{courseId} {
      allow read: if true;
      allow create: if (isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor')) && request.resource.data.instructorId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.instructorId == request.auth.uid);

      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isAdmin() || get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid;

        match /lessons/{lessonId} {
            allow read: if true;
            allow write: if isAdmin() || get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid;

            match /resources/{resourceId} {
                allow read: if true;
                allow write: if isAdmin() || get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid;
            }
        }
      }
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || (resource.data.userId == 'admin' && isAdmin()));
      allow update: if isOwner(resource.data.userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin() || isOwner(resource.data.userId);
    }

    match /transactions/{transId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.instructorId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }
  }
}
