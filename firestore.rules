rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LearnStream Security Rules Documentation
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isInstructor(instructorId) {
      return isSignedIn() && request.auth.uid == instructorId;
    }

    function isPremiumSubscriber() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isPremiumSubscriber == true;
    }

    function canAccessContent(data) {
      return isSignedIn() && (isInstructor(data.instructorId) || data.courseIsFree == true || isPremiumSubscriber());
    }

    function canAccessLesson(data) {
      return isSignedIn() && (isInstructor(data.instructorId) || (data.courseIsFree == true && data.isPremium == false) || isPremiumSubscriber());
    }

    function canAccessResource(data) {
      return isSignedIn() && (isInstructor(data.instructorId) || (data.courseIsFree == true && data.lessonIsPremium == false) || isPremiumSubscriber());
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && (request.resource.data.isPremiumSubscriber == resource.data.isPremiumSubscriber);
      allow delete: if isExistingOwner(userId);

      match /subscriptions/{subscriptionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isExistingOwner(userId);
      }

      match /transactions/{transactionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isExistingOwner(userId);
      }

      match /courseProgress/{courseId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    match /subscriptionPlans/{planId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /courses/{courseId} {
      allow get, list: if isSignedIn();
      allow create: if isInstructor(request.resource.data.instructorId);
      allow update: if resource != null && isInstructor(resource.data.instructorId) && request.resource.data.instructorId == resource.data.instructorId;
      allow delete: if resource != null && isInstructor(resource.data.instructorId);

      match /modules/{moduleId} {
        allow get, list: if canAccessContent(resource.data);
        allow create: if isInstructor(request.resource.data.instructorId) && request.resource.data.courseId == courseId;
        allow update: if resource != null && isInstructor(resource.data.instructorId) && request.resource.data.instructorId == resource.data.instructorId;
        allow delete: if resource != null && isInstructor(resource.data.instructorId);

        match /lessons/{lessonId} {
          allow get, list: if canAccessLesson(resource.data);
          allow create: if isInstructor(request.resource.data.instructorId) && request.resource.data.moduleId == moduleId;
          allow update: if resource != null && isInstructor(resource.data.instructorId) && request.resource.data.instructorId == resource.data.instructorId;
          allow delete: if resource != null && isInstructor(resource.data.instructorId);

          match /resources/{resourceId} {
            allow get, list: if canAccessResource(resource.data);
            allow create: if isInstructor(request.resource.data.instructorId) && request.resource.data.lessonId == lessonId;
            allow update: if resource != null && isInstructor(resource.data.instructorId) && request.resource.data.instructorId == resource.data.instructorId;
            allow delete: if resource != null && isInstructor(resource.data.instructorId);
          }
        }
      }
    }
  }
}