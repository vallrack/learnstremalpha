
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'dvoJg4wCr2e2DZABWjlXITbtVCE3' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isInstructor() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor';
    }

    // ✅ ADMIN: acceso total a todo el sistema
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if true; 
      allow list: if true;
      allow create: if isOwner(userId) && (!request.resource.data.keys().hasAny(['role', 'isPremiumSubscriber', 'premiumUpdatedAt', 'lastEpaycoRef']));
      allow update: if isAdmin() || (isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isPremiumSubscriber', 'premiumUpdatedAt', 'lastEpaycoRef'])));
      allow delete: if isAdmin();

      match /courseProgress/{courseId} {
        allow read: if isOwner(userId) || isAdmin(); 
        allow write: if isOwner(userId) || isAdmin();
      }
      
      match /challenge_submissions/{submissionId} {
        allow read: if true; 
        allow write: if isOwner(userId) || isAdmin();
      }

      match /achievements/{achievementId} {
        allow read: if true; 
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /instructor_applications/{appId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /promotions/{promoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coding_challenges/{challengeId} { 
      allow read: if true; 
      allow write: if isAdmin() || (isSignedIn() && request.resource.data.instructorId == request.auth.uid);
    }
    
    match /courses/{courseId} {
      allow read: if true;
      allow create: if (isAdmin() || isInstructor()) && request.resource.data.instructorId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.instructorId == request.auth.uid);

      match /modules/{moduleId} {
        allow read: if true;
        allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);

        match /lessons/{lessonId} {
            allow read: if true;
            allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);

            match /resources/{resourceId} {
                allow read: if true;
                allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/courses/$(courseId)).data.instructorId == request.auth.uid);
            }
        }
      }
    }

    match /notifications/{notifId} {
      // ✅ 'list' NO puede usar resource.data en este contexto de query - se permite si está firmado
      allow list: if isSignedIn();

      // 'get' sí puede usar resource.data (documento individual)
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      allow update: if isSignedIn() && 
        resource.data.userId == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /transactions/{transId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.instructorId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }
  }
}
