
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information within the LearnStream application.",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "profileImageUrl": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "instructor", "student"] },
        "xp": { "type": "number", "default": 0 },
        "level": { "type": "number", "default": 1 },
        "createdAt": { "type": "string", "format": "date-time" },
        "isPremiumSubscriber": { "type": "boolean" },
        "isActive": { "type": "boolean", "default": true }
      },
      "required": ["id", "displayName", "email", "createdAt"]
    },
    "Course": {
      "title": "Course",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "technology": { "type": "string" },
        "imageUrl": { "type": "string" },
        "instructorId": { "type": "string" },
        "isFree": { "type": "boolean" },
        "closingDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean", "default": true }
      },
      "required": ["id", "title", "technology", "instructorId"]
    },
    "Promotion": {
      "title": "Promotion",
      "type": "object",
      "description": "Descuentos y cupones de campaña creados por el admin.",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string", "description": "Código del cupón (ej: PROMO50)" },
        "discountPercentage": { "type": "number", "description": "Porcentaje de descuento (1-100)" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "usageLimit": { "type": "number", "description": "Máximo de usos permitidos" },
        "timesUsed": { "type": "number", "default": 0 },
        "isActive": { "type": "boolean", "default": true },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "code", "discountPercentage"]
    },
    "CodingChallenge": {
      "title": "CodingChallenge",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Principiante", "Intermedio", "Avanzado"] },
        "technology": { "type": "string" },
        "initialCode": { "type": "string" },
        "solution": { "type": "string" },
        "instructorId": { "type": "string" },
        "isFree": { "type": "boolean", "default": true }
      }
    },
    "ChallengeSubmission": {
      "title": "ChallengeSubmission",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "challengeId": { "type": "string" },
        "score": { "type": "number" },
        "passed": { "type": "boolean" },
        "submittedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/backend/entities/UserProfile" } }
      },
      {
        "path": "/courses/{courseId}",
        "definition": { "entityName": "Course", "schema": { "$ref": "#/backend/entities/Course" } }
      },
      {
        "path": "/promotions/{promoId}",
        "definition": { "entityName": "Promotion", "schema": { "$ref": "#/backend/entities/Promotion" } }
      },
      {
        "path": "/coding_challenges/{challengeId}",
        "definition": { "entityName": "CodingChallenge", "schema": { "$ref": "#/backend/entities/CodingChallenge" } }
      }
    ]
  }
}
