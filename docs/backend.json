
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information within the LearnStream application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "displayName": {
          "type": "string",
          "description": "The user's public display name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "profileImageUrl": {
          "type": "string",
          "description": "URL to the user's profile picture.",
          "format": "uri"
        },
        "role": {
          "type": "string",
          "description": "User role (admin, instructor, student)",
          "enum": ["admin", "instructor", "student"]
        },
        "xp": {
          "type": "number",
          "description": "Experience points earned by the user.",
          "default": 0
        },
        "level": {
          "type": "number",
          "description": "Current level of the user based on XP.",
          "default": 1
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user profile was created.",
          "format": "date-time"
        },
        "lastLoginAt": {
          "type": "string",
          "description": "Timestamp of the user's last login.",
          "format": "date-time"
        },
        "isPremiumSubscriber": {
          "type": "boolean",
          "description": "Indicates if the user has an active premium subscription."
        },
        "isActive": {
          "type": "boolean",
          "description": "Indicates if the account is active.",
          "default": true
        }
      },
      "required": [
        "id",
        "displayName",
        "email",
        "createdAt"
      ]
    },
    "Course": {
      "title": "Course",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "technology": { "type": "string" },
        "imageUrl": { "type": "string" },
        "thumbnailDataUrl": { "type": "string" },
        "previewVideoUrl": { "type": "string" },
        "instructorId": { "type": "string" },
        "instructorName": { "type": "string" },
        "isFree": { "type": "boolean" },
        "closingDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean", "default": true },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "technology", "instructorId"]
    },
    "CodingChallenge": {
      "title": "CodingChallenge",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Principiante", "Intermedio", "Avanzado"] },
        "technology": { "type": "string" },
        "initialCode": { "type": "string" },
        "solution": { "type": "string" },
        "instructorId": { "type": "string" },
        "isFree": { "type": "boolean", "default": true },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChallengeSubmission": {
      "title": "ChallengeSubmission",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "challengeId": { "type": "string" },
        "challengeTitle": { "type": "string" },
        "score": { "type": "number" },
        "feedback": { "type": "string" },
        "passed": { "type": "boolean" },
        "studentCode": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/backend/entities/UserProfile" } }
      },
      {
        "path": "/users/{userId}/challenge_submissions/{submissionId}",
        "definition": { "entityName": "ChallengeSubmission", "schema": { "$ref": "#/backend/entities/ChallengeSubmission" } }
      }
    ]
  }
}
