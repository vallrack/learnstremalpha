
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information within the LearnStream application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "displayName": {
          "type": "string",
          "description": "The user's public display name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "profileImageUrl": {
          "type": "string",
          "description": "URL to the user's profile picture.",
          "format": "uri"
        },
        "role": {
          "type": "string",
          "description": "User role (admin, instructor, student)",
          "enum": ["admin", "instructor", "student"]
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user profile was created.",
          "format": "date-time"
        },
        "lastLoginAt": {
          "type": "string",
          "description": "Timestamp of the user's last login.",
          "format": "date-time"
        },
        "isPremiumSubscriber": {
          "type": "boolean",
          "description": "Indicates if the user has an active premium subscription."
        }
      },
      "required": [
        "id",
        "displayName",
        "email",
        "createdAt"
      ]
    },
    "CodingChallenge": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CodingChallenge",
      "type": "object",
      "description": "Represents a coding challenge or algorithmic problem.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "difficulty": { 
          "type": "string",
          "enum": ["Principiante", "Intermedio", "Avanzado"]
        },
        "category": { "type": "string" },
        "technology": { "type": "string" },
        "initialCode": { "type": "string" },
        "solution": { "type": "string" },
        "instructorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "description", "difficulty", "technology", "instructorId"]
    },
    "Course": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Course",
      "type": "object",
      "description": "Represents a learning course offered on the LearnStream platform.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Course entity."
        },
        "title": {
          "type": "string",
          "description": "The title of the course."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the course content and objectives."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL to the course's thumbnail or banner image.",
          "format": "uri"
        },
        "isFree": {
          "type": "boolean",
          "description": "Indicates if the course is freely accessible without a subscription."
        },
        "difficultyLevel": {
          "type": "string",
          "description": "The perceived difficulty level of the course (e.g., 'Beginner', 'Intermediate', 'Advanced')."
        },
        "instructorId": {
          "type": "string",
          "description": "Reference to the UserProfile of the instructor who created or teaches this course. (Relationship: UserProfile 1:N Course)"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the course was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the course was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "title",
        "description",
        "isFree",
        "instructorId",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/coding_challenges/{challengeId}",
        "definition": {
          "entityName": "CodingChallenge",
          "schema": {
            "$ref": "#/backend/entities/CodingChallenge"
          },
          "description": "Stores algorithmic and design challenges."
        }
      },
      {
        "path": "/courses/{courseId}",
        "definition": {
          "entityName": "Course",
          "schema": {
            "$ref": "#/backend/entities/Course"
          },
          "description": "Top-level collection for all courses."
        }
      }
    ]
  }
}
