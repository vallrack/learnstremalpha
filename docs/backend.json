
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information within the LearnStream application.",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "profileImageUrl": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "instructor", "student"] },
        "xp": { "type": "number", "default": 0 },
        "level": { "type": "number", "default": 1 },
        "createdAt": { "type": "string", "format": "date-time" },
        "isPremiumSubscriber": { "type": "boolean" },
        "isActive": { "type": "boolean", "default": true },
        "instructorStatus": { "type": "string", "enum": ["none", "pending", "active", "rejected"], "default": "none" },
        "revenueSharePercentage": { "type": "number", "default": 70 },
        "totalEarnings": { "type": "number", "default": 0 }
      },
      "required": ["id", "displayName", "email", "createdAt"]
    },
    "InstructorApplication": {
      "title": "InstructorApplication",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "bio": { "type": "string" },
        "specialty": { "type": "string" },
        "paymentReference": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Course": {
      "title": "Course",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "technology": { "type": "string" },
        "imageUrl": { "type": "string" },
        "instructorId": { "type": "string" },
        "isFree": { "type": "boolean" },
        "price": { "type": "number", "default": 0 },
        "closingDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean", "default": true }
      },
      "required": ["id", "title", "technology", "instructorId"]
    },
    "CodingChallenge": {
      "title": "CodingChallenge",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Principiante", "Intermedio", "Avanzado"] },
        "technology": { "type": "string" },
        "type": { "type": "string", "enum": ["code", "wordsearch"], "default": "code" },
        "words": { "type": "array", "items": { "type": "string" }, "description": "Lista de palabras para la sopa de letras." },
        "initialCode": { "type": "string" },
        "solution": { "type": "string" },
        "instructorId": { "type": "string" },
        "isFree": { "type": "boolean", "default": true }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/backend/entities/UserProfile" } }
      },
      {
        "path": "/instructor_applications/{appId}",
        "definition": { "entityName": "InstructorApplication", "schema": { "$ref": "#/backend/entities/InstructorApplication" } }
      },
      {
        "path": "/courses/{courseId}",
        "definition": { "entityName": "Course", "schema": { "$ref": "#/backend/entities/Course" } }
      },
      {
        "path": "/coding_challenges/{challengeId}",
        "definition": { "entityName": "CodingChallenge", "schema": { "$ref": "#/backend/entities/CodingChallenge" } }
      }
    ]
  }
}
